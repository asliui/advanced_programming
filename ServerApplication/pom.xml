<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>ro.uaic.asli</groupId>
    <artifactId>lab10-server-application</artifactId>
    <version>1.0-SNAPSHOT</version>
    <name>Lab 10 — ServerApplication</name>
    <description>Multiplayer quiz TCP server (compulsory / homework / advanced)</description>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.release>21</maven.compiler.release>
    </properties>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <release>21</release>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>3.5.0</version>
                <executions>
                    <execution>
                        <id>compulsory</id>
                        <goals>
                            <goal>java</goal>
                        </goals>
                        <configuration>
                            <mainClass>ro.uaic.asli.lab10.app.Lab10CompulsoryApp</mainClass>
                        </configuration>
                    </execution>
                    <execution>
                        <id>homework</id>
                        <goals>
                            <goal>java</goal>
                        </goals>
                        <configuration>
                            <mainClass>ro.uaic.asli.lab10.app.Lab10HomeworkApp</mainClass>
                        </configuration>
                    </execution>
                    <execution>
                        <id>advanced</id>
                        <goals>
                            <goal>java</goal>
                        </goals>
                        <configuration>
                            <mainClass>ro.uaic.asli.lab10.app.Lab10AdvancedApp</mainClass>
                        </configuration>
                    </execution>
                    <execution>
                        <id>load-demo</id>
                        <goals>
                            <goal>java</goal>
                        </goals>
                        <configuration>
                            <mainClass>ro.uaic.asli.lab10.advanced.VirtualThreadLoadDemo</mainClass>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
